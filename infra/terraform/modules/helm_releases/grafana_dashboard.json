{
  "uid": "logistics-realtime",
  "title": "Logistics Realtime",
  "tags": ["logistics", "realtime"],
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": { "refresh_intervals": ["1s", "5s", "10s", "30s", "1m"] },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "Pipeline latency & freshness",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Avg pipeline latency (s)",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 90 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT avg_latency_s FROM v_latency_summary" } ]
    },
    {
      "type": "stat",
      "title": "p95 pipeline latency (s)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 120 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT p95_latency_s FROM v_latency_summary" } ]
    },
    {
      "type": "stat",
      "title": "Data freshness now()-ingest (s)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 0, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 30 }, { "color": "red", "value": 120 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT data_age_s FROM v_latency_summary" } ]
    },
    {
      "type": "stat",
      "title": "In-process shipments",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "area", "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT sum(in_process_count) AS in_process FROM v_in_process" } ]
    },
    {
      "type": "timeseries",
      "title": "Pipeline latency over time (per 15s)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "timeseries", "rawSql": "SELECT toStartOfInterval(ingested_at, INTERVAL 15 second) AS time, avg(pipeline_latency_s) AS avg_latency_s, quantile(0.95)(pipeline_latency_s) AS p95_latency_s FROM v_latency_shipment WHERE $__timeFilter(ingested_at) GROUP BY time ORDER BY time" } ]
    },
    {
      "type": "row",
      "title": "Order volume & revenue",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }
    },
    {
      "type": "timeseries",
      "title": "Order volume by region",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "timeseries", "rawSql": "SELECT window_start AS time, region_name, SUM(order_count) AS orders FROM v_order_volume_facility WHERE $__timeFilter(window_start) GROUP BY time, region_name ORDER BY time" } ]
    },
    {
      "type": "timeseries",
      "title": "Revenue by branch (VND)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "locale", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": [] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "timeseries", "rawSql": "SELECT window_start AS time, branch_name, SUM(total_revenue_vnd) AS revenue FROM v_financial_facility WHERE $__timeFilter(window_start) GROUP BY time, branch_name ORDER BY time" } ]
    },
    {
      "type": "row",
      "title": "SLA & quality",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "type": "stat",
      "title": "SLA compliance %",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 23 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 95 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT sla_compliance_pct FROM v_sla_quality" } ]
    },
    {
      "type": "stat",
      "title": "First-attempt success %",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 23 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "min": 0, "max": 100, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 70 }, { "color": "green", "value": 85 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT first_attempt_success_pct FROM v_sla_quality" } ]
    },
    {
      "type": "stat",
      "title": "Re-delivery %",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 23 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 15 }, { "color": "red", "value": 30 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT redelivery_pct FROM v_sla_quality" } ]
    },
    {
      "type": "stat",
      "title": "SLA breaches",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 23 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "orange" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "colorMode": "value", "graphMode": "none", "textMode": "auto" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT sla_breach_count FROM v_sla_quality" } ]
    },
    {
      "type": "barchart",
      "title": "Top failure reasons",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "orientation": "horizontal", "xField": "failure_reason_code", "legend": { "showLegend": false }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT failure_reason_code, SUM(failed_delivery_count) AS failed FROM v_failure_reason WHERE $__timeFilter(window_start) GROUP BY failure_reason_code ORDER BY failed DESC LIMIT 10" } ]
    },
    {
      "type": "piechart",
      "title": "Anomalies by type",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "pieType": "donut", "legend": { "displayMode": "list", "placement": "right", "values": ["value"] } },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT anomaly_type, SUM(alert_count) AS cnt FROM v_anomaly_summary GROUP BY anomaly_type ORDER BY cnt DESC" } ]
    },
    {
      "type": "bargauge",
      "title": "Avg journey segment times (s)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 1, "color": { "mode": "continuous-GrYlRd" } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "horizontal", "displayMode": "gradient" },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT avg_e2e_transit_s AS `E2E transit`, avg_pickup_lead_s AS `Pickup lead`, avg_first_mile_s AS `First mile`, avg_origin_po_dwell_s AS `Origin PO dwell`, avg_total_hub_dwell_s AS `Hub dwell`, avg_last_mile_s AS `Last mile` FROM v_journey_times" } ]
    },
    {
      "type": "row",
      "title": "Facility flow & anomalies",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 }
    },
    {
      "type": "table",
      "title": "Facility flow (latest window)",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 36 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true } }, "overrides": [ { "matcher": { "id": "byName", "options": "cap_util_pct" }, "properties": [ { "id": "unit", "value": "percent" }, { "id": "custom.cellOptions", "value": { "type": "gauge" } }, { "id": "max", "value": 100 } ] }, { "matcher": { "id": "byName", "options": "failed_pct" }, "properties": [ { "id": "unit", "value": "percent" } ] } ] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "facility_backlog", "desc": true } ] },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT facility_name, branch_name, region_name, facility_throughput, facility_backlog, round(failed_delivery_rate * 100, 1) AS failed_pct, round(capacity_utilization_pct, 1) AS cap_util_pct FROM v_facility_flow WHERE window_start = (SELECT max(window_start) FROM v_facility_flow) ORDER BY facility_backlog DESC LIMIT 50" } ]
    },
    {
      "type": "table",
      "title": "Recent anomalies",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 36 },
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true } }, "overrides": [ { "matcher": { "id": "byName", "options": "severity" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-text" } }, { "id": "mappings", "value": [ { "type": "value", "options": { "CRITICAL": { "color": "red", "index": 0 }, "WARNING": { "color": "yellow", "index": 1 } } } ] } ] } ] },
      "options": { "showHeader": true, "sortBy": [ { "displayName": "detected_at", "desc": true } ] },
      "targets": [ { "refId": "A", "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" }, "editorType": "sql", "queryType": "table", "rawSql": "SELECT detected_at, anomaly_type, severity, shipment_id, facility_name, region_id, detail FROM v_anomaly_alerts WHERE $__timeFilter(detected_at) ORDER BY detected_at DESC LIMIT 100" } ]
    }
  ]
}
