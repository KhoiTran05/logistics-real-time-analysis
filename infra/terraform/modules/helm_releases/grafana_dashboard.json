          "editorType": "sql",
          "queryType": "table",
          "rawSql": "SELECT f.facility_name AS facility_name, f.branch_name AS branch_name, f.region_name AS region_name, f.facility_backlog AS facility_backlog, d.capacity_per_day AS capacity_per_day, round(f.capacity_utilization_pct, 1) AS cap_util_pct FROM v_facility_flow AS f LEFT JOIN dim_facility AS d ON f.facility_id = d.facility_id WHERE f.window_start = (SELECT max(window_start) FROM v_facility_flow) AND f.capacity_utilization_pct > 70 ORDER BY cap_util_pct DESC LIMIT 50"
